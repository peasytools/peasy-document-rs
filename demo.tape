# peasy-document-rs — Markdown, HTML, CSV conversion (Rust)
# Theme: Dracula
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "Dracula"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasy-document-rs — Markdown, HTML, CSV conversion for Rust"
Enter
Type "# peasyformats.com"
Enter
Sleep 500ms

# Run the demo
Type "cargo run --example demo 2>/dev/null"
Enter
Sleep 5s
